{% include '_base_styles.html.j2' %}
<body>
<div class="doc">
  <div class="doc-rule-top"></div>
  <div class="doc-rule-mid"></div>

  <div class="eyebrow">{{ experiment_id }} · Pre-registered design brief{% if audience != 'exec' %} · {{ audience | upper }}{% endif %}</div>
  <div class="eyebrow-meta">{{ owner_team }} · sealed {{ sealed_at }} · duration {{ duration_text }}</div>

  <h1 class="headline">{{ display_name }}</h1>
  <p class="lede">{{ hypothesis_prose }}</p>

  {# ─────────────────────────────────────────────────────────
     TL;DR — what, why, decision rule
     ───────────────────────────────────────────────────────── #}
  <div class="tldr">
    <div class="tldr-label">At a glance</div>
    <div class="tldr-decision">
      Primary metric is <em>{{ primary_metric_name }}</em>; decision is binary against {{ decision_rule_short }}.
    </div>
    <div class="tldr-because">{{ at_a_glance_prose }}</div>
  </div>

  {# ─────────────────────────────────────────────────────────
     Hero — the design point
     ───────────────────────────────────────────────────────── #}
  <div class="hero">
    <div class="hero-main">
      <div class="lab">Sample required (per arm)</div>
      <div class="val">{{ "{:,}".format(n_per_group) }}</div>
      <div class="unit">to detect a {{ mde_text }} relative effect at α = 0.05, power = 0.80</div>
    </div>
    <div class="hero-side">
      <div class="item"><div class="lab">Baseline</div><div class="val">{{ "%.1f" | format(baseline * 100) }}%</div></div>
      <div class="item"><div class="lab">Total sample</div><div class="val">{{ "{:,}".format(n_total) }}</div></div>
      <div class="item"><div class="lab">Duration</div><div class="val">{{ duration_text }}</div></div>
      <div class="item"><div class="lab">Feasibility</div><div class="val" style="color:#2D8659;">VIABLE</div></div>
    </div>
  </div>

  {# ─────────────────────────────────────────────────────────
     Mechanism (why we think it will work)
     ───────────────────────────────────────────────────────── #}
  <div class="section">
    <div class="section-eyebrow">Mechanism</div>
    <div class="section-title">Why we think this works</div>
    <div class="section-prose">{{ mechanism_prose }}</div>
    {% if historical_baseline_context %}
    <div class="section-prose" style="color:#5A5A55;">{{ historical_baseline_context }}</div>
    {% endif %}
  </div>

  {# ─────────────────────────────────────────────────────────
     Metrics — primary, secondaries, guardrails
     ───────────────────────────────────────────────────────── #}
  <div class="section">
    <div class="section-eyebrow">Metrics</div>
    <div class="section-title">{{ primary_metric_name }} is the verdict-driving metric.</div>
    <div class="section-prose">{{ metrics_section_prose }}</div>

    <div class="metric-row"><div class="lab">Primary</div><div class="body"><div class="name">{{ primary_metric_name }}</div><div class="spec">{{ primary_metric_type | capitalize }} · baseline {{ "%.1f" | format(baseline * 100) }}% · MDE {{ mde_text }} · direction {{ primary_direction | replace("_", " ") }}</div></div></div>
    {% for s in secondary_metric_names %}
    <div class="metric-row"><div class="lab">Secondary</div><div class="body"><div class="name">{{ s }}</div><div class="spec">Leading indicator. Not used for the ship/no-ship decision but informs interpretation.</div></div></div>
    {% endfor %}
    {% for g in guardrails %}
    <div class="metric-row"><div class="lab">Guardrail</div><div class="body"><div class="name">{{ g.metric_name }}</div><div class="spec">Direction {{ g.direction | replace("_", " ") }}. Decision blocks if 90% CI lies past {{ "%.1f" | format(g.nim_relative * 100) }}% relative.</div></div></div>
    {% endfor %}
  </div>

  {# ─────────────────────────────────────────────────────────
     Power analysis chart — required sample vs MDE curve
     ───────────────────────────────────────────────────────── #}
  <div class="section">
    <div class="section-eyebrow">Power</div>
    <div class="section-title">Detecting smaller effects requires much more sample.</div>
    <div class="section-prose">{{ power_section_prose }}</div>

    <div class="chart">
      <svg viewBox="0 0 640 200" width="100%" height="200" xmlns="http://www.w3.org/2000/svg">
        {# y gridlines #}
        <line x1="80" y1="20" x2="600" y2="20" stroke="#E5E3DC" stroke-width="1"/>
        <line x1="80" y1="60" x2="600" y2="60" stroke="#E5E3DC" stroke-width="1"/>
        <line x1="80" y1="100" x2="600" y2="100" stroke="#E5E3DC" stroke-width="1"/>
        <line x1="80" y1="140" x2="600" y2="140" stroke="#E5E3DC" stroke-width="1"/>
        <line x1="80" y1="160" x2="600" y2="160" stroke="#1A1A1A" stroke-width="1"/>

        {# y tick labels #}
        {% for yt in power_y_ticks %}
        <text x="74" y="{{ yt.y + 4 }}" text-anchor="end" font-family="'JetBrains Mono','SF Mono',Menlo,monospace" font-size="10" fill="#5A5A55">{{ yt.label }}</text>
        {% endfor %}
        {# x tick labels #}
        {% for xt in power_x_ticks %}
        <text x="{{ xt.x }}" y="178" text-anchor="middle" font-family="'JetBrains Mono','SF Mono',Menlo,monospace" font-size="10" fill="#5A5A55">{{ xt.label }}</text>
        {% endfor %}

        <polyline points="{{ power_curve_points }}" fill="none" stroke="#006BA2" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>

        {# design point #}
        <line x1="{{ design_x }}" y1="{{ design_y }}" x2="{{ design_x }}" y2="160" stroke="#006BA2" stroke-width="1.2" stroke-dasharray="3,3"/>
        <line x1="80" y1="{{ design_y }}" x2="{{ design_x }}" y2="{{ design_y }}" stroke="#006BA2" stroke-width="1.2" stroke-dasharray="3,3"/>
        <circle cx="{{ design_x }}" cy="{{ design_y }}" r="6" fill="#006BA2" stroke="#F5F4EE" stroke-width="2.5"/>
        <text x="{{ design_x + 12 }}" y="{{ design_y - 6 }}" font-family="'Charter','Iowan Old Style','Georgia',serif" font-style="italic" font-size="13" fill="#1A1A1A" font-weight="700">Our design</text>
        <text x="{{ design_x + 12 }}" y="{{ design_y + 10 }}" font-family="'JetBrains Mono','SF Mono',Menlo,monospace" font-size="10" fill="#5A5A55">{{ mde_text }} MDE · {{ "{:,}".format(n_per_group) }}/arm</text>

        <text x="80" y="196" font-family="'JetBrains Mono','SF Mono',Menlo,monospace" font-size="9" fill="#8A8580" letter-spacing="0.15em">SAMPLE PER ARM (Y) · MINIMUM DETECTABLE EFFECT (X)</text>
      </svg>
      <div class="chart-caption">Smaller effects require disproportionately more sample. Our design point is feasible inside the available {{ assignment_unit }} surface.</div>
    </div>
  </div>

  {# ─────────────────────────────────────────────────────────
     OPERATOR + ENGINEER — assignment + cohorts
     ───────────────────────────────────────────────────────── #}
  {% if audience in ('operator', 'engineer') %}
  <div class="section">
    <div class="section-eyebrow">Assignment + cohorts</div>
    <div class="section-title">First-exposure attribution at the {{ assignment_unit }} level.</div>
    <div class="section-prose">{{ assignment_section_prose }}</div>

    <div class="metric-row"><div class="lab">Unit</div><div class="body"><div class="name">{{ assignment_unit }}</div><div class="spec">One row per ({{ assignment_unit }}, experiment_id) in the assignments table; first_exposure_at gates which events are attributed.</div></div></div>
    <div class="metric-row"><div class="lab">Arms</div><div class="body"><div class="name">{{ expected_arm_ratio_text }}</div><div class="spec">{{ arms | join(' · ') }}</div></div></div>
    {% for c in cohorts %}
    <div class="metric-row"><div class="lab">Cohort</div><div class="body"><div class="name">{{ c }}</div></div></div>
    {% endfor %}
  </div>
  {% endif %}

  {# ─────────────────────────────────────────────────────────
     Decision rules
     ───────────────────────────────────────────────────────── #}
  <div class="section">
    <div class="section-eyebrow">Decision rules</div>
    <div class="section-title">Pre-registered. The analyze verb walks the same tree against the same metrics.</div>
    <div class="section-prose">{{ decision_rule_prose }}</div>

    <div class="rules">
      <div class="rule"><div class="when">Ship</div><div class="then">Primary 95% CI excludes zero on benefit side · no guardrail breach · novelty late-ratio ≥ 0.7</div></div>
      <div class="rule"><div class="when">Lift with caveat</div><div class="then">Real lift but below MDE/2 — surface the caveat in the readout but still consider rolling out</div></div>
      <div class="rule"><div class="when">No-ship · guardrail</div><div class="then">Any guardrail's 90% CI lies past its harm threshold</div></div>
      <div class="rule"><div class="when">No-lift</div><div class="then">Well-powered, primary CI straddles zero with half-width &gt; 2 × MDE</div></div>
      <div class="rule"><div class="when">Inconclusive</div><div class="then">Underpowered (n &lt; required) AND primary CI straddles zero</div></div>
      <div class="rule"><div class="when">Invalid</div><div class="then">SRM χ² p &lt; 0.0005 and no override resolved — investigate assignment</div></div>
    </div>
  </div>

  {# ─────────────────────────────────────────────────────────
     ENGINEER ONLY — integrity lock
     ───────────────────────────────────────────────────────── #}
  {% if audience == 'engineer' %}
  <div class="section">
    <div class="section-eyebrow">Integrity lock · three-part seal</div>
    <div class="section-title">brief.sealed.yaml binds intent + metric definitions + expected shape.</div>
    <div class="section-prose">Tampering with any of the three components after seal will fail
    <code>agentxp.schemas.brief_seal.verify_or_raise</code>; <code>agentxp analyze</code> refuses
    to open a brief whose seal does not verify (R11). This is the architectural wall, not a guideline.</div>

    <div class="prov">
      <div><span class="pk">design_chain_hash</span><span class="pv">{{ design_chain_hash }}</span></div>
      <div><span class="pk">metric_snapshot</span><span class="pv">{{ metric_snapshot_count }} metric{% if metric_snapshot_count != 1 %}s{% endif %} hashed</span></div>
      {% for name, h in metric_snapshot.items() %}<div><span class="pk">  {{ name }}</span><span class="pv">{{ h }}</span></div>{% endfor %}
      <div><span class="pk">expected_shape</span><span class="pv">{{ assignment_unit }} · {{ expected_arm_ratio_text }}</span></div>
      <div><span class="pk">sealed_at</span><span class="pv">{{ sealed_at }}</span></div>
      <div><span class="pk">sealed_by</span><span class="pv">{{ sealed_by }}</span></div>
    </div>
  </div>
  {% endif %}

  <div class="footer">
    <span class="mk">brief.sealed.yaml</span>
    <span>seal {{ design_chain_hash_short }} · {{ sealed_at }} · R1 R11</span>
  </div>
</div>
</body>
</html>
