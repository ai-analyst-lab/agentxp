{#
  experiment-report.html.j2 — single self-contained exec/skeptic report page.

  Rendered by agentxp/render/adapters/html.py with autoescape=True. Every value
  here is an already-escaped VM string EXCEPT `css` and each chart `svg`, which
  are HTML/SVG fragments generated by our own code (brand layer + charts.py) and
  so are marked |safe. No external assets, no JS — offline-safe.
#}<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ vm.experiment_name }} — experiment report</title>
<style>{{ css|safe }}</style>
</head>
<body class="xp-doc xp-theme-{{ audience }}">

{% if is_draft %}
<div class="xp-draft-banner" role="alert">
  DRAFT — UNVERIFIED. {{ receipts.status_reason }}
</div>
{% endif %}

<p class="xp-eyebrow">Experiment report · {{ vm.experiment_id }}</p>
<h1 class="xp-headline">{{ vm.experiment_name }}</h1>

{# verdict-first: the badge ALWAYS carries the word, colour is reinforcement #}
<p>
  <span class="xp-verdict-badge xp-verdict-badge--{{ verdict_modifier }}">
    <span class="xp-verdict-word">{{ vm.verdict }}</span>
  </span>
  <span class="xp-metric-label">{{ vm.confidence_label }}</span>
</p>
<p>{{ vm.rationale_one_line }}</p>

{# headline metrics — primary row first #}
<div class="xp-metric-row">
{% for m in vm.metric_table %}
  <div class="xp-metric">
    <span class="xp-metric-label">{{ m.name }}</span>
    <span class="xp-metric-value">{{ m.lift_str }}</span>
    <span class="xp-metric-label">95% CI {{ m.ci_95 }} · {{ m.status }}</span>
  </div>
{% endfor %}
</div>

{# charts — only the ones whose stored numbers exist are present #}
{% for c in charts %}
<figure class="xp-chart">
  {{ c.svg|safe }}
  <figcaption class="xp-chart-caption">{{ c.caption }}</figcaption>
</figure>
{% endfor %}

{# diagnostics strip #}
<div class="xp-callout-strip">
  <div class="xp-stat">
    <span class="xp-stat-label">SRM</span>
    <span class="xp-stat-value">{% if vm.diagnostics.srm_pass %}pass{% else %}FAIL{% endif %}</span>
  </div>
  {% if vm.diagnostics.sample_pct is not none %}
  <div class="xp-stat">
    <span class="xp-stat-label">Sample</span>
    <span class="xp-stat-value">{{ vm.diagnostics.sample_pct }}%</span>
  </div>
  {% endif %}
  {% if vm.diagnostics.late_ratio is not none %}
  <div class="xp-stat">
    <span class="xp-stat-label">Late-window ratio</span>
    <span class="xp-stat-value">{{ vm.diagnostics.late_ratio }}</span>
  </div>
  {% endif %}
</div>

{% if vm.diagnostics.guardrails_violated %}
<h2 class="xp-eyebrow">Guardrail violations</h2>
<ul>
{% for g in vm.diagnostics.guardrails_violated %}
  <li><span class="xp-badge xp-badge--fail">{{ g.metric }}</span> {{ g.detail }}</li>
{% endfor %}
</ul>
{% endif %}

{% if vm.uncertainty_notes %}
<h2 class="xp-eyebrow">What I'm not sure about</h2>
<ul>
{% for note in vm.uncertainty_notes %}
  <li>{{ note }}</li>
{% endfor %}
</ul>
{% endif %}

{% if show_audit %}
<h2 class="xp-eyebrow">Audit trail</h2>
<table class="xp-audit-table">
  <thead><tr><th>artifact</th><th>committed</th><th>ref</th></tr></thead>
  <tbody>
  {% for row in vm.audit_trail %}
    <tr>
      <td>{{ row.stage }}</td>
      <td>{{ row.committed_at }}</td>
      <td>{{ row.action_id }}</td>
    </tr>
  {% endfor %}
  </tbody>
</table>
{% endif %}

{# receipts footer — MANDATORY. The page is un-renderable without it. #}
<footer class="xp-receipts-footer">
  <p>
    <span class="xp-render-status xp-render-status--{{ receipts.status_class }}">{{ receipts.status }}</span>
    {{ receipts.status_reason }}
  </p>
  <dl>
    <dt>Replay</dt><dd>{{ receipts.replay_command }}</dd>
    <dt>Chain</dt><dd>{{ receipts.chain_token }}</dd>
    {% if receipts.chain_hash_full %}
    <dt>Chain hash (recorded)</dt>
    <dd>{{ receipts.chain_hash_short }}… <span class="xp-metric-label">(full: {{ receipts.chain_hash_full }})</span></dd>
    {% endif %}
    {% if receipts.locked_brief_hash %}
    <dt>Locked-brief hash</dt><dd>{{ receipts.locked_brief_hash }}</dd>
    {% endif %}
    {% if receipts.agentxp_version %}
    <dt>agentxp version</dt><dd>{{ receipts.agentxp_version }}</dd>
    {% endif %}
    <dt>Generated</dt><dd>{{ vm.generated_at }}</dd>
  </dl>
</footer>

</body>
</html>
